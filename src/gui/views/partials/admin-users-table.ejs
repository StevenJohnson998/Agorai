<div class="bg-slate-900 rounded-xl border border-slate-800 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-800">
          <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Name</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase hidden md:table-cell">Email</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Status</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase hidden md:table-cell">Role</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase hidden lg:table-cell">Last activity</th>
          <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(u) { %>
          <tr class="border-b border-slate-800/50 hover:bg-slate-800/30">
            <td class="px-4 py-3 text-slate-200"><%= u.name %></td>
            <td class="px-4 py-3 text-slate-400 hidden md:table-cell"><%= u.email %></td>
            <td class="px-4 py-3">
              <% if (u.status === 'approved') { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-green-900/30 text-green-300 border border-green-800/50">approved</span>
              <% } else if (u.status === 'pending') { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-yellow-900/30 text-yellow-300 border border-yellow-800/50">pending</span>
              <% } else { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-red-900/30 text-red-300 border border-red-800/50">rejected</span>
              <% } %>
              <% if (u.accountLocked) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-red-900/30 text-red-300 border border-red-800/50 ml-1">locked</span>
              <% } %>
            </td>
            <td class="px-4 py-3 text-slate-400 hidden md:table-cell"><%= u.role %></td>
            <td class="px-4 py-3 text-slate-500 text-xs hidden lg:table-cell">
              <% if (u.lastActivity) { %>
                <%= new Date(u.lastActivity).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
              <% } else { %>
                Never
              <% } %>
            </td>
            <td class="px-4 py-3 text-right">
              <% if (u.id !== user.id) { %>
                <div class="flex items-center justify-end gap-1">
                  <% if (u.status === 'pending') { %>
                    <form method="POST" action="<%= envPath %>/admin/users/<%= u.id %>/approve"
                      hx-post="<%= envPath %>/admin/users/<%= u.id %>/approve"
                      hx-target="#users-table"
                      hx-swap="innerHTML"
                      class="inline">
                      <button type="submit" class="px-2 py-1 text-xs bg-green-700 hover:bg-green-600 text-white rounded transition-colors">Approve</button>
                    </form>
                    <form method="POST" action="<%= envPath %>/admin/users/<%= u.id %>/reject"
                      hx-post="<%= envPath %>/admin/users/<%= u.id %>/reject"
                      hx-target="#users-table"
                      hx-swap="innerHTML"
                      class="inline">
                      <button type="submit" class="px-2 py-1 text-xs bg-red-700 hover:bg-red-600 text-white rounded transition-colors">Reject</button>
                    </form>
                  <% } %>
                  <form method="POST" action="<%= envPath %>/admin/users/<%= u.id %>/delete"
                    hx-post="<%= envPath %>/admin/users/<%= u.id %>/delete"
                    hx-target="#users-table"
                    hx-swap="innerHTML"
                    hx-confirm="Delete user <%= u.name %>?"
                    class="inline">
                    <button type="submit" class="px-2 py-1 text-xs bg-slate-700 hover:bg-slate-600 text-slate-300 rounded transition-colors">Delete</button>
                  </form>
                </div>
              <% } else { %>
                <span class="text-xs text-slate-600">You</span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <div class="px-4 py-2 text-xs text-slate-500 border-t border-slate-800">
    <%= users.length %> user<%= users.length !== 1 ? 's' : '' %>
  </div>
</div>
