<% if (projects.length === 0) { %>
  <p class="text-xs text-slate-600 px-2">No projects yet</p>
<% } %>
<% projects.forEach(function(project) { %>
  <div class="mb-3">
    <div class="flex items-center gap-1.5 px-2 py-1 text-sm text-slate-300 font-medium">
      <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
      <%= project.name %>
    </div>
    <% (project.conversations || []).forEach(function(conv) { %>
      <a href="<%= envPath %>/c/<%= conv.id %>"
        class="block px-2 py-1 ml-4 text-sm text-slate-400 hover:bg-slate-800/50 hover:text-slate-200 rounded-md transition-colors"
        hx-get="<%= envPath %>/c/<%= conv.id %>"
        hx-target="#main-content"
        hx-push-url="true">
        # <%= conv.title %>
      </a>
    <% }); %>
  </div>
<% }); %>
