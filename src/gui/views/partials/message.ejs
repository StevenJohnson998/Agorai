<%
  var agent = agentMap.get(message.fromAgent);
  var agentName = agent ? agent.name : message.fromAgent;
  var isHuman = agent && (agent.type === 'human' || agentName.startsWith('user:'));
  var isMe = message.fromAgent === user.agentId;
  var isStatus = message.type === 'status';
  var time = new Date(message.createdAt);
  var timeStr = time.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });

  // Type badge colors
  var typeBadge = '';
  var badgeColor = '';
  if (message.type && message.type !== 'message' && message.type !== 'status') {
    typeBadge = message.type;
    switch(message.type) {
      case 'spec': badgeColor = 'bg-purple-900/50 text-purple-300'; break;
      case 'result': badgeColor = 'bg-green-900/50 text-green-300'; break;
      case 'review': badgeColor = 'bg-yellow-900/50 text-yellow-300'; break;
      case 'question': badgeColor = 'bg-blue-900/50 text-blue-300'; break;
      case 'proposal': badgeColor = 'bg-indigo-900/50 text-indigo-300'; break;
      case 'decision': badgeColor = 'bg-orange-900/50 text-orange-300'; break;
      default: badgeColor = 'bg-slate-700/50 text-slate-400';
    }
  }

  // Display name: strip "user:" prefix for humans
  var displayName = agentName.replace(/^user:/, '');
%>
<% if (isStatus) { %>
  <!-- System/status message — centered, subtle -->
  <div class="flex justify-center my-1" data-created-at="<%= message.createdAt %>">
    <div class="text-[11px] text-slate-500 bg-slate-900/50 px-3 py-1 rounded-full">
      <%= message.content %>
      <span class="text-slate-600 ml-1"><%= timeStr %></span>
    </div>
  </div>
<% } else { %>
  <div class="flex <%= isMe ? 'justify-end' : 'justify-start' %> group" data-created-at="<%= message.createdAt %>">
    <div class="max-w-[92%] sm:max-w-[85%] lg:max-w-[70%] <%= isMe ? 'bg-brand-600/20 border-brand-700/30' : 'bg-slate-800/80 border-slate-700/50' %> border rounded-lg px-3 py-2">
      <!-- Header -->
      <div class="flex items-center gap-2 mb-0.5">
        <% if (!isMe) { %>
          <span class="text-xs font-medium <%= isHuman ? 'text-brand-400' : 'text-emerald-400' %>"><%= displayName %></span>
        <% } %>
        <% if (typeBadge) { %>
          <span class="text-[10px] px-1.5 py-0.5 rounded-full <%= badgeColor %>"><%= typeBadge %></span>
        <% } %>
        <span class="text-[10px] text-slate-600 ml-auto"><%= timeStr %></span>
      </div>
      <!-- Content -->
      <div class="text-sm text-slate-200 whitespace-pre-wrap break-words message-content"><%= message.content %></div>
      <% if (message.attachments && message.attachments.length > 0) { %>
        <div class="mt-1.5 space-y-1">
          <% message.attachments.forEach(function(att) { %>
            <div class="flex items-center gap-2 text-xs bg-slate-900/50 rounded px-2 py-1.5 border border-slate-700/50">
              <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
              <span class="text-slate-300 truncate flex-1"><%= att.filename %></span>
              <span class="text-slate-500"><%= att.size < 1048576 ? (att.size / 1024).toFixed(1) + ' KB' : (att.size / 1048576).toFixed(1) + ' MB' %></span>
              <a href="<%= envPath %>/c/<%= message.conversationId %>/attachment/<%= att.id %>"
                 target="_blank" rel="noopener" title="Open"
                 class="text-brand-400 hover:text-brand-300 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
              <a href="<%= envPath %>/c/<%= message.conversationId %>/attachment/<%= att.id %>/download"
                 title="Download"
                 class="text-brand-400 hover:text-brand-300 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              </a>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
<% } %>
