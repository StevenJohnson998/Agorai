<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Agorai</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script>htmx.config.allowScriptTags = true;</script>
  <script src="https://unpkg.com/htmx-ext-sse@2.3.0/sse.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <link rel="stylesheet" href="<%= basePath %>/static/style.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { 50:'#eff6ff',100:'#dbeafe',200:'#bfdbfe',400:'#60a5fa',500:'#3b82f6',600:'#2563eb',700:'#1d4ed8' }
          }
        }
      }
    }
  </script>
</head>
<body class="h-full bg-slate-950 text-slate-100">
  <div class="h-full flex flex-col">

    <!-- Header -->
    <header class="bg-slate-900 border-b border-slate-800 px-4 py-2 flex items-center justify-between shrink-0">
      <div class="flex items-center gap-3">
        <!-- Mobile menu toggle -->
        <button id="sidebar-toggle" class="lg:hidden p-1 text-slate-400 hover:text-white" onclick="toggleSidebar()">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <a href="<%= envPath %>/c/" class="text-lg font-bold text-white tracking-tight">Agorai</a>
      </div>

      <div class="flex items-center gap-3">
        <!-- Online agents badges (admin only) -->
        <% if (user.role === 'admin' || user.role === 'superadmin') { %>
        <div class="hidden sm:flex items-center gap-1 overflow-x-auto max-w-xs">
          <% onlineAgents.slice(0, 5).forEach(function(agent) { %>
            <%- include('partials/agent-badge', { agent, online: true }) %>
          <% }); %>
          <% if (onlineAgents.length > 5) { %>
            <span class="text-xs text-slate-500">+<%= onlineAgents.length - 5 %></span>
          <% } %>
        </div>
        <% } %>

        <!-- Rate warning icon (admin only) -->
        <% if (user.role === 'admin' || user.role === 'superadmin') { %>
        <div id="rate-warning" class="hidden relative cursor-pointer" title="High message rate detected">
          <svg class="w-5 h-5 text-red-500 animate-pulse" fill="currentColor" viewBox="0 0 24 24">
            <path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
          </svg>
          <span id="rate-warning-count" class="absolute -top-1 -right-1 bg-red-600 text-white text-[9px] font-bold rounded-full w-3.5 h-3.5 flex items-center justify-center"></span>
        </div>
        <% } %>

        <!-- Verbosity -->
        <select id="verbosity-select"
          class="bg-slate-800 border border-slate-700 text-slate-300 text-xs rounded-lg px-2 py-1 focus:ring-brand-500 focus:border-brand-500"
          onchange="updateVerbosity(this.value)">
          <option value="concise" <%= user.verbosity === 'concise' ? 'selected' : '' %>>Concise</option>
          <option value="normal" <%= user.verbosity === 'normal' ? 'selected' : '' %>>Normal</option>
          <option value="detailed" <%= user.verbosity === 'detailed' ? 'selected' : '' %>>Detailed</option>
        </select>

        <!-- User menu -->
        <div class="flex items-center gap-2">
          <span class="text-sm text-slate-400 hidden sm:inline"><%= user.name %></span>
          <% if (user.role === 'admin' || user.role === 'superadmin') { %>
            <a href="<%= envPath %>/admin" class="text-xs text-slate-500 hover:text-slate-300" title="Admin">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </a>
          <% } %>
          <form method="POST" action="<%= basePath %>/logout" class="inline">
            <button type="submit" class="text-xs text-slate-500 hover:text-slate-300" title="Sign out">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            </button>
          </form>
        </div>
      </div>
    </header>

    <!-- Main content area -->
    <div class="flex-1 flex overflow-hidden relative">

      <!-- Sidebar overlay (mobile) -->
      <div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/50 z-20 lg:hidden" onclick="toggleSidebar()"></div>

      <!-- Sidebar -->
      <aside id="sidebar" class="w-64 bg-slate-900 border-r border-slate-800 flex-shrink-0 overflow-y-auto fixed lg:static inset-y-0 left-0 z-30 -translate-x-full lg:translate-x-0 transition-transform top-[49px] lg:top-0">

        <!-- Mobile close button -->
        <button class="lg:hidden absolute top-2 right-2 p-1 text-slate-500 hover:text-white z-40" onclick="toggleSidebar()" aria-label="Close sidebar">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

        <!-- Projects section (pt-10 on mobile to avoid overlap with close button) -->
        <div class="p-3 pt-10 lg:pt-3">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Projects</h3>
            <button onclick="promptNewProject()" class="text-xs text-slate-500 hover:text-slate-300 transition-colors px-1" title="New project">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </button>
          </div>
          <% if (projects.length === 0) { %>
            <p class="text-xs text-slate-600 px-2">No projects yet</p>
          <% } %>
          <% var isAdmin = user.role === 'admin' || user.role === 'superadmin'; %>
          <% projects.forEach(function(project) { %>
            <% var canManageProject = isAdmin || project.createdBy === user.agentId; %>
            <div class="mb-3">
              <div class="group/proj flex items-center gap-1.5 px-2 py-1 text-sm text-slate-300 font-medium relative">
                <svg class="w-3.5 h-3.5 text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                <span class="truncate flex-1"><%= project.name %></span>
                <% if (canManageProject) { %>
                <button class="opacity-100 lg:opacity-0 lg:group-hover/proj:opacity-100 p-0.5 text-slate-500 hover:text-slate-300 transition-opacity shrink-0"
                  onclick="event.stopPropagation(); toggleProjMenu('<%= project.id %>')">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
                </button>
                <div id="proj-menu-<%= project.id %>" class="hidden absolute right-0 top-full z-50 mt-1 w-44 bg-slate-800 border border-slate-700 rounded-lg shadow-xl py-1">
                  <button class="w-full text-left px-3 py-1.5 text-xs text-slate-300 hover:bg-slate-700 transition-colors"
                    onclick="promptNewConversation('<%= project.id %>')">
                    New conversation
                  </button>
                  <button class="w-full text-left px-3 py-1.5 text-xs text-slate-300 hover:bg-slate-700 transition-colors"
                    onclick="startRenameProject('<%= project.id %>', '<%= project.name.replace(/'/g, "\\'") %>')">
                    Rename
                  </button>
                  <form method="POST" action="<%= envPath %>/c/toggle-access-project/<%= project.id %>">
                    <button type="submit" class="w-full text-left px-3 py-1.5 text-xs text-slate-300 hover:bg-slate-700 transition-colors">
                      <%= project.accessMode === 'hidden' ? 'Show' : 'Hide' %>
                    </button>
                  </form>
                  <form method="POST" action="<%= envPath %>/c/delete-project/<%= project.id %>"
                    onsubmit="return confirm('Delete project and all its conversations?')">
                    <button type="submit" class="w-full text-left px-3 py-1.5 text-xs text-red-400 hover:bg-slate-700 transition-colors">
                      Delete
                    </button>
                  </form>
                </div>
                <% } %>
              </div>
              <!-- Conversations -->
              <% conversations.filter(function(c) { return c.projectId === project.id; }).forEach(function(conv) {
                   var canManage = isAdmin || conv.createdBy === user.agentId;
              %>
                <div class="group/conv flex items-center ml-4 rounded-md transition-colors relative
                  <%= activeConversation && activeConversation.conversation.id === conv.id ? 'bg-slate-800' : 'hover:bg-slate-800/50' %>">
                  <a href="<%= envPath %>/c/<%= conv.id %>"
                    class="flex-1 px-2 py-1 text-sm truncate
                      <%= activeConversation && activeConversation.conversation.id === conv.id ? 'text-white' : 'text-slate-400 hover:text-slate-200' %>"
                    hx-get="<%= envPath %>/c/<%= conv.id %>"
                    hx-target="#main-content"
                    hx-push-url="true">
                    # <%= conv.title %>
                  </a>
                  <% if (canManage) { %>
                  <button class="opacity-100 lg:opacity-0 lg:group-hover/conv:opacity-100 p-1 text-slate-500 hover:text-slate-300 transition-opacity shrink-0"
                    onclick="event.stopPropagation(); toggleConvMenu('<%= conv.id %>')">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01"/></svg>
                  </button>
                  <div id="conv-menu-<%= conv.id %>" class="hidden absolute right-0 top-full z-50 mt-1 w-36 bg-slate-800 border border-slate-700 rounded-lg shadow-xl py-1">
                    <button class="w-full text-left px-3 py-1.5 text-xs text-slate-300 hover:bg-slate-700 transition-colors"
                      onclick="startRename('<%= conv.id %>', '<%= conv.title.replace(/'/g, "\\'") %>')">
                      Rename
                    </button>
                    <form method="POST" action="<%= envPath %>/c/<%= conv.id %>/toggle-access">
                      <button type="submit" class="w-full text-left px-3 py-1.5 text-xs text-slate-300 hover:bg-slate-700 transition-colors">
                        <%= conv.accessMode === 'hidden' ? 'Show' : 'Hide' %>
                      </button>
                    </form>
                    <form method="POST" action="<%= envPath %>/c/<%= conv.id %>/delete"
                      onsubmit="return confirm('Delete this conversation?')">
                      <button type="submit" class="w-full text-left px-3 py-1.5 text-xs text-red-400 hover:bg-slate-700 transition-colors">
                        Delete
                      </button>
                    </form>
                  </div>
                  <% } %>
                </div>
              <% }); %>
            </div>
          <% }); %>
        </div>

        <!-- Agents section (admin only) -->
        <% if (user.role === 'admin' || user.role === 'superadmin') { %>
        <div class="p-3 border-t border-slate-800">
          <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Agents</h3>
          <% agents.forEach(function(agent) { %>
            <% var online = onlineAgents.some(function(a) { return a.id === agent.id; });
               var dotClass = agent.status === 'error' ? 'bg-red-500' : (online ? 'bg-green-400' : 'bg-slate-600');
               var textClass = agent.status === 'error' ? 'text-red-400' : (online ? 'text-slate-200' : 'text-slate-500');
            %>
            <div class="flex items-center gap-2 px-2 py-1 text-sm" title="<%= agent.status === 'error' ? (agent.statusMessage || 'Error') : (online ? 'Online' : 'Offline') %>">
              <span class="w-2 h-2 rounded-full flex-shrink-0 <%= dotClass %>"></span>
              <span class="<%= textClass %> truncate"><%= agent.name %></span>
              <span class="text-xs text-slate-600 ml-auto"><%= agent.type %></span>
            </div>
          <% }); %>
        </div>
        <% } %>
      </aside>

      <!-- Main content -->
      <main id="main-content" class="flex-1 flex flex-col overflow-hidden">
        <% if (activeConversation) { %>
          <%- include('conversation', {
            user: user,
            conversation: activeConversation.conversation,
            project: activeConversation.project,
            messages: activeConversation.messages,
            agentMap: activeConversation.agentMap,
            subscribers: activeConversation.subscribers,
            agents: agents,
            onlineAgents: onlineAgents,
            envPath: envPath,
            basePath: basePath,
            title: activeConversation.conversation.title,
          }) %>
        <% } else if (typeof activeView !== 'undefined' && activeView === 'conversations-list') { %>
          <%- include('conversations-list', {
            user: user,
            projects: projectsWithConvs,
            envPath: envPath,
            basePath: basePath,
          }) %>
        <% } else { %>
          <!-- Dashboard overview -->
          <div class="flex-1 flex items-center justify-center p-6">
            <div class="text-center max-w-md">
              <h2 class="text-2xl font-bold text-white mb-2">Welcome back, <%= user.name %></h2>
              <p class="text-slate-400 mb-6">Select a conversation from the sidebar to get started.</p>

              <div class="grid grid-cols-3 gap-4 mb-8">
                <div class="bg-slate-900 rounded-xl border border-slate-800 p-4">
                  <div class="text-2xl font-bold text-white"><%= onlineAgents.length %></div>
                  <div class="text-xs text-slate-500 mt-1">Agents online</div>
                </div>
                <div class="bg-slate-900 rounded-xl border border-slate-800 p-4">
                  <div class="text-2xl font-bold text-white"><%= projects.length %></div>
                  <div class="text-xs text-slate-500 mt-1">Projects</div>
                </div>
                <div class="bg-slate-900 rounded-xl border border-slate-800 p-4">
                  <div class="text-2xl font-bold text-white"><%= unreadCount %></div>
                  <div class="text-xs text-slate-500 mt-1">Unread</div>
                </div>
              </div>

              <% if (agents.length === 0) { %>
                <p class="text-sm text-slate-500">No agents connected yet. Start the bridge with <code class="bg-slate-800 px-1 rounded">agorai serve</code></p>
              <% } %>
            </div>
          </div>
        <% } %>
      </main>
    </div>
  </div>

  <!-- Toast container -->
  <div id="toast-container" class="fixed bottom-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none"></div>

  <script>
    // Toast notifications
    function showToast(message, type) {
      type = type || 'success';
      var container = document.getElementById('toast-container');
      var toast = document.createElement('div');
      var colors = type === 'error' ? 'bg-red-600' : type === 'warning' ? 'bg-yellow-600' : 'bg-emerald-600';
      toast.className = 'pointer-events-auto px-4 py-2.5 rounded-lg text-white text-sm shadow-lg ' + colors + ' transform translate-x-full opacity-0 transition-all duration-300';
      toast.textContent = message;
      container.appendChild(toast);
      requestAnimationFrame(function() {
        toast.classList.remove('translate-x-full', 'opacity-0');
      });
      setTimeout(function() {
        toast.classList.add('translate-x-full', 'opacity-0');
        setTimeout(function() { toast.remove(); }, 300);
      }, 3000);
    }

    function toggleSidebar() {
      var sidebar = document.getElementById('sidebar');
      var overlay = document.getElementById('sidebar-overlay');
      sidebar.classList.toggle('-translate-x-full');
      overlay.classList.toggle('hidden');
    }

    function updateVerbosity(level) {
      fetch('<%= envPath %>/api/settings/verbosity', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ verbosity: level })
      });
    }

    // Close sidebar on navigation (mobile)
    document.body.addEventListener('htmx:afterSwap', function() {
      var sidebar = document.getElementById('sidebar');
      if (sidebar && !sidebar.classList.contains('-translate-x-full') && window.innerWidth < 1024) {
        toggleSidebar();
      }
    });

    // Close all menus
    function closeAllMenus() {
      document.querySelectorAll('[id^="conv-menu-"], [id^="proj-menu-"]').forEach(function(m) {
        m.classList.add('hidden');
      });
    }

    // Conversation context menu
    function toggleConvMenu(id) {
      var menu = document.getElementById('conv-menu-' + id);
      var wasHidden = menu.classList.contains('hidden');
      closeAllMenus();
      if (wasHidden) menu.classList.remove('hidden');
    }

    // Project context menu
    function toggleProjMenu(id) {
      var menu = document.getElementById('proj-menu-' + id);
      var wasHidden = menu.classList.contains('hidden');
      closeAllMenus();
      if (wasHidden) menu.classList.remove('hidden');
    }

    // Close menus on click outside
    document.addEventListener('click', function(e) {
      if (!e.target.closest('[id^="conv-menu-"]') && !e.target.closest('[id^="proj-menu-"]')
          && !e.target.closest('button[onclick*="toggleConvMenu"]') && !e.target.closest('button[onclick*="toggleProjMenu"]')) {
        closeAllMenus();
      }
    });

    // Helper: submit form and show toast
    function submitWithToast(action, data, successMsg) {
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = action;
      Object.keys(data).forEach(function(key) {
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = key;
        input.value = data[key];
        form.appendChild(input);
      });
      document.body.appendChild(form);
      form.submit();
    }

    // New project (from sidebar + button)
    function promptNewProject() {
      var name = prompt('Project name:');
      if (name && name.trim()) {
        submitWithToast('<%= envPath %>/c/create-project', { name: name.trim() });
      }
    }

    // New conversation in project (from project menu)
    function promptNewConversation(projectId) {
      closeAllMenus();
      var title = prompt('Conversation name:');
      if (title && title.trim()) {
        submitWithToast('<%= envPath %>/c/create-conversation', { projectId: projectId, title: title.trim() });
      }
    }

    // Rename conversation
    function startRename(convId, currentTitle) {
      closeAllMenus();
      var newTitle = prompt('Rename conversation:', currentTitle);
      if (newTitle && newTitle.trim() && newTitle.trim() !== currentTitle) {
        submitWithToast('<%= envPath %>/c/' + convId + '/rename', { title: newTitle.trim() });
      }
    }

    // Rename project
    function startRenameProject(projectId, currentName) {
      closeAllMenus();
      var newName = prompt('Rename project:', currentName);
      if (newName && newName.trim() && newName.trim() !== currentName) {
        submitWithToast('<%= envPath %>/c/rename-project/' + projectId, { name: newName.trim() });
      }
    }

    // Show toast from URL query param (set by server redirects)
    (function() {
      var params = new URLSearchParams(window.location.search);
      var msg = params.get('toast');
      var type = params.get('toast_type') || 'success';
      if (msg) {
        showToast(decodeURIComponent(msg), type);
        // Clean URL
        var url = new URL(window.location);
        url.searchParams.delete('toast');
        url.searchParams.delete('toast_type');
        history.replaceState(null, '', url.pathname + url.hash);
      }
    })();

    // Rate warning polling (admin only)
    <% if (user.role === 'admin' || user.role === 'superadmin') { %>
    (function() {
      var el = document.getElementById('rate-warning');
      var countEl = document.getElementById('rate-warning-count');
      if (!el) return;
      var tooltip = '';
      function checkRate() {
        fetch('<%= envPath %>/api/rate-warning')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.warning) {
              el.classList.remove('hidden');
              countEl.textContent = data.conversations.length;
              tooltip = 'High message rate (' + data.threshold + '/' + data.windowMinutes + 'min):\n' +
                data.conversations.map(function(c) { return c.title + ': ' + c.count + ' msgs'; }).join('\n');
              el.title = tooltip;
            } else {
              el.classList.add('hidden');
            }
          })
          .catch(function() {});
      }
      checkRate();
      setInterval(checkRate, 30000);
    })();
    <% } %>
  </script>
</body>
</html>
