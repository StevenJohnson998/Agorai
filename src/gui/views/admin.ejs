<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Agorai</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <link rel="stylesheet" href="<%= basePath %>/static/style.css">
</head>
<body class="h-full bg-slate-950 text-slate-100">
  <div class="h-full flex flex-col">
    <!-- Header -->
    <header class="bg-slate-900 border-b border-slate-800 px-4 py-2 flex items-center justify-between shrink-0">
      <div class="flex items-center gap-3">
        <a href="<%= envPath %>/c/" class="text-lg font-bold text-white tracking-tight">Agorai</a>
        <span class="text-slate-500">/</span>
        <span class="text-sm text-slate-400">Admin</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-sm text-slate-400"><%= user.name %></span>
        <a href="<%= envPath %>/c/" class="text-xs text-slate-500 hover:text-slate-300">Back</a>
      </div>
    </header>

    <main class="flex-1 overflow-y-auto p-4 sm:p-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-xl font-bold text-white mb-4">User Management</h2>

        <div id="users-table">
          <%- include('partials/admin-users-table', { user: user, users: users, envPath: envPath, basePath: basePath }) %>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
